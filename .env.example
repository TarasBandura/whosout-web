# Optional overrides (set in Vercel → Project → Environment Variables)
NEXT_PUBLIC_SITE_URL=https://joinwhosout.com
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/whos-out/TODO
NEXT_PUBLIC_GOOGLE_PLAY_URL=https://play.google.com/store/apps/details?id=TODO

# Hangout landing metadata (reads public open hangouts via PostgREST; anon key must stay public-safe)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Dev-only second scheme button on marketing CTAs (`1` to show)
# NEXT_PUBLIC_SHOW_ALT_DEEP_LINK=1
